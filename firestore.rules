rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // ===============================================================
    // Assumed Data Model
    // ===============================================================
    //
    // Collection: services
    // Document ID: auto-generated
    // Fields:
    //   - title: string (required) - Title of the service
    //   - category: string (required) - Category of the service (AraMommy, AraVax, AraSihat, Other)
    //   - imageUrl: string (required) - URL of the promotional image
    //   - rankOrder: number (required) - Order of the service in the list
    //
    // ===============================================================

    // ===============================================================
    // Helper Functions
    // ===============================================================
    function isAuthenticated() {
      return request.auth != null;
    }

    function isAdmin() {
      return isAuthenticated() && (
        (request.auth.token.email == "asyrafsaharudin@hsohealthcare.com") ||
        exists(/databases/$(database)/documents/admins/$(request.auth.token.email))
      );
    }

    function isValidService() {
      let data = request.resource.data;
      return data.keys().hasAll(['title', 'category', 'imageUrl', 'rankOrder']) &&
             data.keys().hasOnly(['title', 'category', 'imageUrl', 'rankOrder']) &&
             data.title is string && data.title.size() > 0 && data.title.size() < 100 &&
             data.category is string && data.category.size() > 0 && data.category.size() < 50 &&
             data.imageUrl is string && data.imageUrl.size() > 0 && data.imageUrl.size() < 1000 &&
             data.rankOrder is number;
    }

    function isValidLocation() {
      let data = request.resource.data;
      return data.keys().hasAll(['branchName', 'address', 'phone', 'whatsapp', 'operatingHours', 'googleMapsUrl', 'wazeUrl']) &&
             data.branchName is string && data.branchName.size() > 0 && data.branchName.size() < 100 &&
             data.address is string && data.address.size() > 0 && data.address.size() < 500 &&
             data.phone is string && data.phone.size() < 50 &&
             data.whatsapp is string && data.whatsapp.size() < 50 &&
             data.operatingHours is string && data.operatingHours.size() < 200 &&
             data.googleMapsUrl is string && data.googleMapsUrl.size() < 1000 &&
             data.wazeUrl is string && data.wazeUrl.size() < 1000 &&
             (!('imageUrl' in data) || (data.imageUrl is string && data.imageUrl.size() < 1000)) &&
             (!('landmark' in data) || (data.landmark is string && data.landmark.size() < 500));
    }

    function isValidPanel() {
      let data = request.resource.data;
      return data.keys().hasAll(['name', 'imageUrl', 'availableLocations']) &&
             data.name is string && data.name.size() > 0 && data.name.size() < 100 &&
             data.imageUrl is string && data.imageUrl.size() > 0 && data.imageUrl.size() < 1000 &&
             data.availableLocations is list && data.availableLocations.size() <= 50;
    }

    function isValidCollaborator() {
      let data = request.resource.data;
      return data.keys().hasAll(['name', 'location', 'imageUrl']) &&
             data.name is string && data.name.size() > 0 && data.name.size() < 100 &&
             data.location is string && data.location.size() > 0 && data.location.size() < 200 &&
             data.imageUrl is string && data.imageUrl.size() > 0 && data.imageUrl.size() < 1000;
    }

    function isValidCategory() {
      let data = request.resource.data;
      return data.keys().hasAll(['name', 'rankOrder']) &&
             data.keys().hasOnly(['name', 'rankOrder']) &&
             data.name is string && data.name.size() > 0 && data.name.size() < 50 &&
             data.rankOrder is number;
    }

    match /services/{serviceId} {
      allow read: if true;
      allow create: if isAdmin() && isValidService();
      allow update: if isAdmin() && isValidService();
      allow delete: if isAdmin();
    }

    match /locations/{locationId} {
      allow read: if true;
      allow create: if isAdmin() && isValidLocation();
      allow update: if isAdmin() && isValidLocation();
      allow delete: if isAdmin();
    }

    match /panels/{panelId} {
      allow read: if true;
      allow create: if isAdmin() && isValidPanel();
      allow update: if isAdmin() && isValidPanel();
      allow delete: if isAdmin();
    }

    match /collaborators/{collabId} {
      allow read: if true;
      allow create: if isAdmin() && isValidCollaborator();
      allow update: if isAdmin() && isValidCollaborator();
      allow delete: if isAdmin();
    }

    match /vendors/{vendorId} {
      allow read: if true;
      allow write: if isAdmin();
    }

    match /settings/{settingId} {
      allow read: if true;
      allow write: if isAdmin();
    }

    match /reviews/{reviewId} {
      allow read: if true;
      allow write: if isAdmin();
    }

    match /leads/{leadId} {
      allow read: if isAdmin();
      allow create: if true;
      allow update, delete: if isAdmin();
    }

    match /serviceCategories/{categoryId} {
      allow read: if true;
      allow create: if isAdmin() && isValidCategory();
      allow update: if isAdmin() && isValidCategory();
      allow delete: if isAdmin();
    }

    match /admins/{adminId} {
      allow read: if isAuthenticated();
      allow write: if isAdmin();
    }

    match /test/{docId} {
      allow read: if true;
    }
  }
}
