rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    
    // ===============================================================
    // Helper Functions
    // ===============================================================
    // Verifies that the user is logged into the Firebase system
    function isAuthenticated() {
      return request.auth != null;
    }

    // ===============================================================
    // PUBLIC READ COLLECTIONS (Website Content)
    // Anyone on the internet can read these to view the live website.
    // Only logged-in staff can create, update, or delete them.
    // ===============================================================

    match /services/{document=**} {
      allow read: if true;
      allow write: if isAuthenticated();
    }

    match /locations/{document=**} {
      allow read: if true;
      allow write: if isAuthenticated();
    }

    match /panels/{document=**} {
      allow read: if true;
      allow write: if isAuthenticated();
    }

    match /collaborators/{document=**} {
      allow read: if true;
      allow write: if isAuthenticated();
    }

    match /vendors/{document=**} {
      allow read: if true;
      allow write: if isAuthenticated();
    }

    match /reviews/{document=**} {
      allow read: if true;
      allow write: if isAuthenticated();
    }

    match /settings/{document=**} {
      allow read: if true;
      allow write: if isAuthenticated();
    }

    match /pages/{document=**} {
      allow read: if true;
      allow write: if isAuthenticated();
    }

    // ===============================================================
    // LEADS COLLECTION (Customer Inquiries / Bookings)
    // Anyone on the internet can create a lead (submit a form).
    // Only logged-in staff can view, edit, or delete the leads.
    // ===============================================================
    match /leads/{document=**} {
      allow create: if true;
      allow read, update, delete: if isAuthenticated();
    }

    // ===============================================================
    // ADMINS COLLECTION (Staff Management)
    // Logged-in users need to read this to verify their role.
    // Only logged-in staff can add or remove other staff.
    // ===============================================================
    match /admins/{document=**} {
      allow read: if isAuthenticated();
      allow write: if isAuthenticated();
    }
  }
}